{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Setup Dev Env",
      "type": "shell",
      "windows": {
        "command": "${workspaceFolder}/scripts/setup-dev.bat"
      },
      "linux": {
        "command": "${workspaceFolder}/scripts/setup-dev.sh"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "Run Backend",
      "type": "shell",
      "command": "uv",
      "args": ["run", "main.py"],
      "options": {
        "cwd": "${workspaceFolder}/backend/src"
      }
    },
    {
      "label": "Run Frontend",
      "type": "npm",
      "script": "dev",
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      }
    },
    {
      "label": "Run Dramatiq",
      "type": "shell",
      "command": "uv",
      "args": ["run", "dramatiq", "main", "--processes", "2", "--threads", "4"],
      "options": {
        "cwd": "${workspaceFolder}/queue/src"
      }
    }
  ]
}
