{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run Backend",
      "type": "shell",
      "command": "uv",
      "args": ["run", "main.py"],
      "options": {
        "cwd": "${workspaceFolder}/backend/src"
      }
    },
    {
      "label": "Run Frontend",
      "type": "shell",
      "command": "pnpm",
      "args": ["dev"],
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      }
    },
    {
      "label": "Run Dramatiq",
      "type": "shell",
      "command": "uv",
      "args": ["run", "dramatiq", "main", "--processes", "2", "--threads", "4"],
      "options": {
        "cwd": "${workspaceFolder}/worker/src"
      }
    }
  ]
}
