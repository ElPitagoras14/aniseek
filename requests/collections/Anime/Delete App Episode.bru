meta {
  name: Delete App Episode
  type: http
  seq: 15
}

delete {
  url: {{scraper-host}}/api/v1/animes/download/single/{{anime-id}}/{{episode-number}}
  body: none
  auth: bearer
}

auth:bearer {
  token: {{auth-token}}
}

vars:pre-request {
  anime-id: gachiakuta
  episode-number: 13
}

settings {
  encodeUrl: true
  timeout: 0
}
