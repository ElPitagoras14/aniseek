# Docker: Prefix for container names
COMPOSE_PROJECT_NAME=aniseek

# Auth: NextAuth session encryption
AUTH_SECRET=change-me-in-production

# Database: PostgreSQL credentials
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres

# Backend: JWT and admin credentials
SECRET_KEY=change-me-in-production
ALGORITHM=HS256
ADMIN_USER=admin
ADMIN_PASS=admin123
BRAVE_PATH=/usr/bin/brave-browser  # Optional: path to Brave Browser (uses Playwright chromium by default if not found)

# Storage
DOCKER_DATA_FOLDER=/srv/data  # Host path
ANIMES_FOLDER=/animes         # Container path

# Worker: Download task configuration
MAX_DOWNLOAD_RETRIES=5
RETRY_DOWNLOAD_INTERVAL=15
DRAMATIQ_PROCESSES=2
DRAMATIQ_THREADS=4

# Tokens: JWT expiration times
ACCESS_TOKEN_EXP_MIN=30
REFRESH_TOKEN_EXP_DAY=10

# Development only
# AUTH_TRUST_HOST=true
# POSTGRES_PORT=4003
# REDIS_PORT=4004
# POSTGRES_URL=
# REDIS_URL=
