# General
ENVIRONMENT=dev  # dev | prod
COMPOSE_PROJECT_NAME=aniseek

# Infraestructura — PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres
DB_URL=postgresql://postgres:postgres@localhost:4003/postgres

# Infraestructura — Redis
REDIS_URL=redis://localhost:4004

# Auth — secretos
SECRET_KEY=change-me-in-production
ALGORITHM=HS256

# Auth — sesiones
ACCESS_TOKEN_EXP_MIN=30
REFRESH_TOKEN_EXP_DAY=10

# Auth — admin
AUTH_ENABLED=true

# Storage
ANIMES_FOLDER=/animes

# Frontend (build-time — dev only, Docker usa API_URL del contenedor)
API_URL=http://localhost:8000

# Worker
DRAMATIQ_PROCESSES=2
DRAMATIQ_THREADS=4
MAX_DOWNLOAD_RETRIES=5
RETRY_DOWNLOAD_INTERVAL=15

# Puertos locales (desarrollo)
POSTGRES_PORT=4003
REDIS_PORT=4004
