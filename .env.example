# Docker: Prefix for Docker container names.
COMPOSE_PROJECT_NAME=aniseek

# Optional Port Assignments (Used if running services locally or for external access)
# PostgreSQL and Redis ports - only needed for local development outside Docker
POSTGRES_PORT=4003
REDIS_PORT=4004

# Auth Configuration
# AUTH_SECRET: Secret used by NextAuth for session encryption. Must be a long, random string.
AUTH_SECRET=supersecretprodkey
# AUTH_TRUST_HOST: Trust the host header from the proxy (nginx)
AUTH_TRUST_HOST=true
# NEXTAUTH_URL: URL that NextAuth uses for authentication callbacks.
# Use the IP or domain of your server (without port, nginx handles it).
NEXTAUTH_URL=http://192.168.1.100

# Databases
# POSTGRES_USER, POSTGRES_PASSWORD, POSTGRES_DB: Credentials for PostgreSQL database.
POSTGRES_USER=produser
POSTGRES_PASSWORD=prodpass
POSTGRES_DB=proddb
# DEV only: Direct connection URLs for local development outside Docker.
POSTGRES_URL=postgresql://produser:prodpass@192.168.1.71:4003/proddb
REDIS_URL=redis://192.168.1.71:4004


# Backend Configuration
# SECRET_KEY: Secret key used for JWT signing in the API. Must be a long, random string.
SECRET_KEY=prodsecretkey
# ALGORITHM: Algorithm used for JWT signing (e.g., HS256).
ALGORITHM=HS256
# ADMIN_USER, ADMIN_PASS: Credentials for the initial administrator user created on startup.
ADMIN_USER=admin
ADMIN_PASS=admin123

# Animes folder (Linux server assumed)
# DOCKER_DATA_FOLDER: Host path where persistent data (like downloaded animes) will be stored.
DOCKER_DATA_FOLDER=/srv/data
# ANIMES_FOLDER: Internal path inside the containers where animes are stored. Must match the volume mount defined in docker-compose.yaml.
ANIMES_FOLDER=/animes

# Dramatiq Configuration
# MAX_DOWNLOAD_RETRIES: Maximum number of times a download task will be retried upon failure.
MAX_DOWNLOAD_RETRIES=5
# RETRY_DOWNLOAD_INTERVAL: Interval (in seconds) between download retries.
RETRY_DOWNLOAD_INTERVAL=15
# DRAMATIQ_PROCESSES: Number of processes for the Dramatiq worker.
DRAMATIQ_PROCESSES=2
# DRAMATIQ_THREADS: Number of threads per process for the Dramatiq worker.
DRAMATIQ_THREADS=4

# Tokens Configuration
# ACCESS_TOKEN_EXP_MIN: Access token expiration time in minutes.
ACCESS_TOKEN_EXP_MIN=30
# REFRESH_TOKEN_EXP_DAY: Refresh token expiration time in days.
REFRESH_TOKEN_EXP_DAY=10
